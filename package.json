{
  "name": "my-remoteservice",
  "version": "1.0.0",
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4.7.0",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap-cloud-sdk/resilience": "^4.7.0",
    "@sap/cds": "^9"
  },
  "cds": {
    "requires": {
      "SupplierService": {
        "kind": "odata",
        "model": "srv/external/SupplierService",

        "[production]": {
          "credentials": {
            "url": "https://real-supplier-system.example.com/odata/v4/SupplierService",
            "authentication": "BasicAuthentication",
            "username": "{{SUPPLIER_USER}}",
            "password": "{{SUPPLIER_PASSWORD}}"
          }
        }
      }
    }
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true
}
